# Pulled datasets are huge (multi-GB video/parquet) — never commit the raw data.
# Lightweight collection history (每日新增 / 趋势) is local runtime data.
pulls/
pull_history.local.json
hf_change_history.local.json
quality_status.local.json
.quality_cache/
.quality_reports/
**/quality_clips/

# Python virtual env / caches
.venv/
__pycache__/
*.py[cod]

# Runtime logs
*.log

# Local Claude/editor settings
.claude/
.vscode/
.idea/

# HF cache (if ever created here)
.cache/

# Locally-saved HF token from the 切换账号 dialog — never commit / share.
.hf_token
