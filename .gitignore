# Pulled datasets are huge (multi-GB video/parquet) — never commit the raw data.
# The lightweight collection history (每日新增 / 趋势) lives in the git-committed
# root file ./pull_history.json instead, so a clone gets history without pulls/.
pulls/

# Python virtual env / caches
.venv/
__pycache__/
*.py[cod]

# Runtime logs
*.log

# Local Claude/editor settings
.claude/
.vscode/
.idea/

# HF cache (if ever created here)
.cache/
